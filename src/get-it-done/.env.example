# CouchDB instance URL (no trailing slash)
VITE_COUCH_URL=http://localhost:5984

# CouchDB username — must match COUCHDB_USER in docker-compose.yml
VITE_COUCH_USER=admin

# VAPID public key for Web Push (generate with: npx web-push generate-vapid-keys)
# The private key goes in push-server/.env — never expose it here
VITE_VAPID_PUBLIC_KEY=
